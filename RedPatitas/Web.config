<?xml version="1.0" encoding="utf-8"?>
<!--
  Para obtener más información sobre cómo configurar la aplicación ASP.NET, visite
  https://go.microsoft.com/fwlink/?LinkId=169433
  -->
<configuration>
  <connectionStrings>
    <add name="CapaDatos.Properties.Settings.RedPatitasConnectionString" connectionString="Data Source=.\SQLEXPRESS;Initial Catalog=RedPatitas;Integrated Security=True" providerName="System.Data.SqlClient" />
    <add name="CapaDatos.Properties.Settings.RedPatitasConnectionString1" connectionString="Data Source=.\SQLEXPRESS;Initial Catalog=RedPatitas;Integrated Security=True;Encrypt=True;TrustServerCertificate=True" providerName="System.Data.SqlClient" />
    <add name="CapaDatos.Properties.Settings.RedPatitasConnectionString2" connectionString="Data Source=.\SQLEXPRESS;Initial Catalog=RedPatitas;Integrated Security=True;Encrypt=True;TrustServerCertificate=True" providerName="System.Data.SqlClient" />
  </connectionStrings>
  <appSettings>
    <add key="ValidationSettings:UnobtrusiveValidationMode" value="None" />
  </appSettings>
  <system.web>
    <compilation debug="true" targetFramework="4.8.1" />
    <!-- Aumentar límite a 20MB (20480 KB) para permitir subir fotos pesadas de cámaras modernas -->
    <httpRuntime targetFramework="4.8.1" maxRequestLength="20480" executionTimeout="360" />
    <globalization requestEncoding="utf-8" responseEncoding="utf-8" fileEncoding="utf-8"
      culture="es-PE" uiCulture="es-PE" />
    <customErrors mode="Off" defaultRedirect="~/Public/404.aspx">
      <error statusCode="404" redirect="~/Public/404.aspx" />
    </customErrors>
  </system.web>

  <!-- Configuración de IIS para límites de tamaño de archivo (20MB = 20971520 bytes) -->
  <system.webServer>
    <security>
      <requestFiltering>
        <requestLimits maxAllowedContentLength="20971520" />
      </requestFiltering>
    </security>
  </system.webServer>
</configuration>